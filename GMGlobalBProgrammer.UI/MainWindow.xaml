<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="GMGlobalBProgrammer.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GMGlobalBProgrammer.UI"
        mc:Ignorable="d"
        Title="GM Global B Programmer" Height="700" Width="1000">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Device Connection Panel -->
        <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="Device:" VerticalAlignment="Center" Margin="0,0,5,0" />
                <ComboBox Name="DeviceCombo" Width="200" Margin="0,0,10,0" />
                <Button Name="ConnectButton" Content="Connect" Width="80" Margin="0,0,10,0" Click="ConnectButton_Click" />
                <Button Name="DisconnectButton" Content="Disconnect" Width="80" Margin="0,0,10,0" Click="DisconnectButton_Click" />
                <Ellipse Name="ConnectionIndicator" Fill="Red" Width="12" Height="12" Margin="0,0,5,0" />
                <TextBlock Name="ConnectionStatusText" Text="Disconnected" VerticalAlignment="Center" />
                <TextBlock Text="Channel:" Margin="20,0,5,0" VerticalAlignment="Center" />
                <TextBlock Name="ChannelInfoText" Text="29-bit CAN @ 500kbps" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
        
        <!-- Function Buttons Panel -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Name="SBATButton" Content="SBAT" Width="100" Height="30" Margin="5" Click="SBATButton_Click" />
                <Button Name="VINWriteButton" Content="VIN Write" Width="100" Height="30" Margin="5" Click="VINWriteButton_Click" />
                <Button Name="InjectorButton" Content="Injector" Width="100" Height="30" Margin="5" Click="InjectorButton_Click" />
                <Button Name="LoadLogFileButton" Content="Load Log File" Width="100" Height="30" Margin="5" Click="LoadLogFileButton_Click" />
            </StackPanel>
        </Border>
        
        <!-- Dynamic Function Panel -->
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <ScrollViewer>
                <StackPanel Name="FunctionPanel">
                    <TextBlock Text="Select a function to begin" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" />
                    
                    <!-- SBAT Panel -->
                    <StackPanel Name="SBATPanel" Visibility="Collapsed">
                        <TextBlock Text="SBAT Request" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" />
                        <Button Name="ExecuteSBATButton" Content="Request SBAT" Width="120" Height="30" Margin="5" Click="ExecuteSBATButton_Click" />
                        <ProgressBar Name="SBATProgress" Height="20" Margin="5" Visibility="Collapsed" />
                        <TextBlock Name="SBATStatusText" Text="" Margin="5" />
                    </StackPanel>
                    
                    <!-- VIN Write Panel -->
                    <StackPanel Name="VINWritePanel" Visibility="Collapsed">
                        <TextBlock Text="VIN Write" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="New VIN:" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBox Name="VINTextBox" Grid.Column="1" MaxLength="17" Text="1HGCM8263MA123456" Margin="0,0,10,0" />
                            <Button Name="WriteVINButton" Grid.Column="2" Content="Write VIN" Width="80" Height="30" Click="WriteVINButton_Click" />
                        </Grid>
                        <ProgressBar Name="VINProgress" Height="20" Margin="5" Visibility="Collapsed" />
                        <TextBlock Name="VINStatusText" Text="" Margin="5" />
                    </StackPanel>
                    
                    <!-- Injector Panel -->
                    <StackPanel Name="InjectorPanel" Visibility="Collapsed">
                        <TextBlock Text="Injector Programming" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" />
                        <Button Name="LoadInjectorFileButton" Content="Load Log File" Width="120" Height="30" Margin="5" Click="LoadInjectorFileButton_Click" />
                        <Button Name="ProgramInjectorsButton" Content="Program Injectors" Width="120" Height="30" Margin="5" Click="ProgramInjectorsButton_Click" />
                        <ProgressBar Name="InjectorProgress" Height="20" Margin="5" Visibility="Collapsed" />
                        <TextBlock Name="InjectorStatusText" Text="" Margin="5" />
                        <DataGrid Name="InjectorDataGrid" AutoGenerateColumns="False" Height="150" Margin="5" Visibility="Collapsed">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Cylinder" Binding="{Binding CylinderNumber}" Width="80" />
                                <DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" Width="120" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
        
        <!-- CAN Log Panel -->
        <Border Grid.Row="3" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Name="ClearLogButton" Content="Clear" Width="60" Height="25" Margin="5" Click="ClearLogButton_Click" />
                    <Button Name="SaveLogButton" Content="Save Log" Width="80" Height="25" Margin="5" Click="SaveLogButton_Click" />
                    <ComboBox Name="FilterCombo" Width="100" Margin="5" SelectedIndex="0">
                        <ComboBoxItem Content="All" />
                        <ComboBoxItem Content="TX" />
                        <ComboBoxItem Content="RX" />
                        <ComboBoxItem Content="Errors" />
                    </ComboBox>
                </StackPanel>
                
                <GroupBox Header="Live CAN Log" DockPanel.Dock="Top">
                    <DataGrid Name="CANLogGrid" AutoGenerateColumns="False" Height="150">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="100" />
                            <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="40" />
                            <DataGridTextColumn Header="CAN-ID" Binding="{Binding CanIdText}" Width="60" />
                            <DataGridTextColumn Header="Data" Binding="{Binding DataText}" Width="*" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </DockPanel>
        </Border>
        
        <!-- Status Bar -->
        <StatusBar Grid.Row="4" Height="30">
            <StatusBarItem>
                <TextBlock Name="StatusText" Text="Ready" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Name="ProgressText" Text="Progress: " />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
